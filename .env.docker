# Environment variables for Docker Compose

# Database Configuration
DB_USER=malikina
DB_PASSWORD=malikina
DB_NAME=malikina
DB_HOST=postgres
DB_PORT=5432

# Node Environment
NODE_ENV=production
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173,https://malikina.vercel.app

# PgAdmin (only used with debug profile)
PGADMIN_EMAIL=admin@malikina.local
PGADMIN_PASSWORD=change_me_to_secure_password

# Optional - OCR Space API Key
OCR_SPACE_API_KEY=
